{
  "description": "A 'Save the Date' and sign-up page for my bday",
  "author": "EliasSchaut",
  "private": true,
  "type": "commonjs",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "homepage": "https://github.com/EliasSchaut/BdayHero#README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/EliasSchaut/BdayHero.git"
  },
  "scripts": {
    "start": "concurrently \"pnpm start:server\" \"pnpm start:client\"",
    "start:server": "pnpm --filter @bdayhero/server start",
    "start:client": "pnpm --filter @bdayhero/client start",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter @bdayhero/server dev",
    "dev:client": "pnpm --filter @bdayhero/client dev",
    "test:server": "pnpm --filter @bdayhero/server test",
    "build": "pnpm build:db && concurrently \"pnpm build:server\" \"pnpm build:client\" \"pnpm build:shared\"",
    "build:server": "pnpm --filter @bdayhero/server build",
    "build:client": "pnpm --filter @bdayhero/client build",
    "build:shared": "pnpm --filter @bdayhero/shared build",
    "build:db": "pnpm prisma migrate dev --schema=./schema.prisma --name dev"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@apollo/server-plugin-landing-page-graphql-playground>@apollo/server": "^4 || ^5",
        "@angular-devkit/core>chokidar": "^3 || ^4"
      }
    },
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@tsparticles/engine",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^7.7.0",
    "tsup": "^8.5.1"
  }
}
