{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "server",
  "compilerOptions": {
    "assets": [
      { "include": "./locales", "watchAssets": true },
      { "include": "./types/generated", "watchAssets": true }
    ],
    "tsConfigPath": "./server/tsconfig.json"
  }
}
